# Open Carrusel — deploy en GCP (Cloud Run + HTTPS Load Balancer).
# Copiá este archivo a deploy/gcp.env y completá los 3 primeros valores.
# Lo usan los scripts deploy/gcp-*.sh y deploy/cloudrun-deploy.sh.

# --- Completar ---
PROJECT_ID=                       # ID del proyecto GCP (no el número)
APP_DOMAIN=carruseles.30x.com     # dominio/subdominio público del sitio
GITHUB_REPO=Hainrixz/open-carrusel  # owner/repo (para Workload Identity de CI)

# --- Defaults razonables (cambiar solo si hace falta) ---
REGION=us-east1
SERVICE=open-carrusel             # nombre del servicio de Cloud Run
AR_REPO=open-carrusel             # repo de Artifact Registry (imágenes)

# Buckets GCS de estado (deben ser únicos globalmente — llevan el project id).
# Se crean en gcp-setup.sh; no hace falta tocarlos.
BUCKET_DATA=${PROJECT_ID}-oc-data       # /app/data (DB JSON, usuarias, tokens)
BUCKET_UPLOADS=${PROJECT_ID}-oc-uploads # /app/public/uploads (imágenes subidas)

# Cuentas de servicio (se crean en gcp-setup.sh).
# (los IDs de service account deben tener 6-30 caracteres)
RUNTIME_SA=oc-runtime             # identidad con la que corre Cloud Run
CI_SA=oc-ci-deploy                # identidad que usa GitHub Actions (vía WIF)

# Nombres de recursos del Load Balancer (se crean en gcp-loadbalancer.sh).
LB_IP_NAME=oc-ip
NEG_NAME=oc-neg
BACKEND_NAME=oc-backend
CERT_NAME=oc-cert
URLMAP_NAME=oc-urlmap
