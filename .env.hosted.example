# Open Carrusel — modo hosteado. Copiá este archivo a .env.hosted y completalo.

# Enciende login, tokens por usuaria y protección de rutas. Sin esto la app se
# comporta como la versión local de siempre.
HOSTED_MODE=1

# Dominio público (lo usa Caddy para el certificado TLS).
DOMAIN=carruseles.ejemplo.com

# Secreto raíz: firma sesiones y cifra los tokens de Claude en reposo.
# Generalo con:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# ⚠ Si lo cambiás, TODAS las usuarias tienen que volver a pegar su token.
AUTH_SECRET=

# Token interno con el que el subproceso de Claude le pega a la API por loopback.
# Generalo igual que AUTH_SECRET (otro valor).
INTERNAL_API_TOKEN=

# Cuentas centrales de Claude: pagan la cola 30x (/agent-jobs, sin usuaria
# logueada) y son el fallback del editor cuando la usuaria no conectó su token.
# Cada una es un `claude setup-token` de una cuenta Max/Team.
#
# FALLBACK POR LÍMITE: podés configurar VARIAS. Cuando una llega a su límite de
# uso, el sistema la pone en cooldown y rota a la siguiente sola. Formas de
# configurarlas (se combinan y de-duplican; el orden es el de preferencia):
#   - varias en una línea, separadas por coma:  CLAUDE_TEAM_OAUTH_TOKEN=tok1,tok2
#   - numeradas (una por variable):             CLAUDE_TEAM_OAUTH_TOKEN_1=...
#                                               CLAUDE_TEAM_OAUTH_TOKEN_2=...
# CLAUDE_RUNNER_OAUTH_TOKEN sigue funcionando (nombre legacy). Sin ninguna, la
# cola no corre en modo hosteado y el editor exige token propio de cada usuaria.
# CLAUDE_TEAM_OAUTH_TOKEN=
# CLAUDE_TEAM_OAUTH_TOKEN_2=

# Opcional: minutos de cooldown de una cuenta tras llegar a su límite (default 300 = 5h,
# la ventana de reset de Max/Team). Bajalo si tus cuentas resetean más rápido.
# CLAUDE_TOKEN_COOLDOWN_MIN=300

# Opcional: presupuesto máximo por generación (default 8.00).
# CLAUDE_MAX_BUDGET_USD=8.00

# Cookie de sesión de Instagram para scrapear los referentes desde el server.
# CRÍTICO en la nube: Instagram sirve a las IPs de datacenter (Cloud Run, etc.)
# un HTML recortado SIN el JSON del post, así que sin esto solo se rescata la
# PORTADA (1 lámina) y la generación falla con "carrusel incompleto". En la compu
# de una diseñadora (IP residencial) no hace falta.
# Cómo obtenerla: logueate en instagram.com → DevTools → Application → Cookies →
# instagram.com → copiá el valor de `sessionid`. Rota/vence cada tanto: si vuelve
# a fallar la ingesta, renovala.
# IG_SESSIONID=
