/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# app data (user-generated)
/data/
/public/uploads/
/public/exports/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# Playwright MCP session logs (ephemeral)
.playwright-mcp/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# audit / tooling artifacts
.playwright-cli/
open-carrusel*.log
/.next/cache/

# OS
Thumbs.db

# throwaway standalone slide render pages (export workaround)
/public/sdf-slides/

# render de prueba 30x
render-*.png

# Brand kit (520MB de assets, vive en la carpeta pero no en git)
30x/brand-kit/

# PNGs de revision de calidad (artefactos de trabajo del agente)
/.quality/
