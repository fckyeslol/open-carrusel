# Open Carrusel — configuración local. Copiá este archivo a `.env.local` y completá.
# Cada diseñadora usa SU PROPIO token de Prewave (no compartir uno entre varias).

# Token JWT de tu sesión de Prewave (dura 30 días). Con esto la app trae SOLO tus
# carruseles asignados ("por diseñar"). Si lo dejás vacío, lo podés pegar en el panel /30x.
PREWAVE_TOKEN=

# Base de la API de Prewave (dejalo así salvo que cambie).
PREWAVE_API_BASE=https://api.prewave.oracle30x.co/api/v1

# Cuántos carruseles genera en paralelo (default 4, tope 8; cada uno usa Chrome + Claude).
# Bajalo a 1 si la máquina va justa de RAM/CPU.
THIRTYX_MAX_CONCURRENT=4

# Solo si el Claude CLI no está en el PATH (normalmente la app lo autodetecta).
# CLAUDE_CLI_PATH=

# --- Higgsfield (generación nativa de imágenes con IA) ---
# Credenciales de la API Cloud de Higgsfield. Sacalas de https://cloud.higgsfield.ai/api-keys
# Si las dejás vacías, la generación de imágenes queda deshabilitada (el resto de la app sigue igual).
HF_API_KEY=
HF_API_SECRET=
